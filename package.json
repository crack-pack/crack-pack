{
  "name": "crack-pack",
  "version": "0.9.0",
  "description": "A Magic: The Gathering pack-collation simulator — as realistic as the available print-sheet data allows (see ASSUMPTIONS.md; contributions welcome)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-data.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "node --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "demo": "node examples/open-a-pack.ts",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": ["mtg", "magic-the-gathering", "collation", "packs", "simulation", "booster"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crack-pack/crack-pack.git"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
